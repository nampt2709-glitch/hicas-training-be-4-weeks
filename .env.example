# Sao chép thành file .env ở thư mục gốc solution và điền giá trị thật.
# MSSQL_SA_PASSWORD: mật khẩu đăng nhập SQL Server cho tài khoản sa — docker-compose dùng cho container sqlserver
# VÀ tự chèn vào ConnectionStrings của CommentAPI cùng ApartmentAPI (không cần gõ lại mật khẩu ở hai chỗ).
# Mật khẩu phải đủ mạnh theo yêu cầu của SQL Server (độ dài, chữ hoa/thường, số, ký tự đặc biệt).

MSSQL_SA_PASSWORD=YourStrongPasswordHere

SQLSERVER_PORT=18433

REDIS_PORT=6379

COMMENTAPI_PORT=8080
APARTMENTAPI_PORT=8081

ASPNETCORE_ENVIRONMENT=Development

# Chạy API bằng dotnet run trên máy (không trong Docker): tạo CommentAPI/.env và ApartmentAPI/.env
# từ file .env.example trong từng project — đặt Password= trong chuỗi kết nối TRÙNG với MSSQL_SA_PASSWORD ở trên,
# Server=localhost,18433 (hoặc cổng SQLSERVER_PORT bạn đã chọn).
