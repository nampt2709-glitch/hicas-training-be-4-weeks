# ApartmentAPI chạy local (dotnet run) khi SQL/Redis chạy bằng docker-compose:
# - Server=localhost,18433 (hoặc đổi cổng cho khớp SQLSERVER_PORT trong .env gốc solution).
# - Database=HICAS_Apartment_API (khác CommentAPI nhưng CÙNG instance SQL, CÙNG sa).
# - Password= phải TRÙNG MSSQL_SA_PASSWORD trong file .env ở thư mục gốc solution.
# - Redis: localhost + REDIS_PORT (mặc định 6379) — CÙNG Redis với CommentAPI (InstanceName khác trong code nên không đụng khóa).
ConnectionStrings__DefaultConnection=Server=localhost,18433;Database=HICAS_Apartment_API;User Id=sa;Password=YourStrongPasswordHere;TrustServerCertificate=True;MultipleActiveResultSets=True
ConnectionStrings__Redis=localhost:6379
