{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "ApartmentAPI",
    "Audience": "ApartmentAPIClients",
    "SigningKey": "ApartmentAPI_Dev_SigningKey_Change_In_Production_Min_32_Chars!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Cache": {
    "EntityTtlSeconds": 120,
    "PreferInProcessCache": false
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "AttachmentStorage": {
    "RootRelativePath": "uploads/attachments",
    "MaxFileSizeBytes": 20971520
  }
}
